###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=changeme-generate-a-real-secret
###< symfony/framework-bundle ###

###> symfony/mailer ###
# null://null  — discard all (default dev)
# smtp://user:pass@smtp.example.com:587
MAILER_DSN=null://null
###< symfony/mailer ###

###> symfony/messenger ###
# RabbitMQ (used in Docker Compose)
MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
###< symfony/messenger ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://app:secret@127.0.0.1:5433/email_dispatch?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> email providers ###
# log | smtp | mailgun
DEFAULT_EMAIL_PROVIDER=log

MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=sandbox.mailgun.org
MAILGUN_BASE_URL=https://api.mailgun.net
# Set to true to skip real HTTP calls (local/test)
MAILGUN_FAKE_MODE=true
# Shared secret for webhook verification (leave empty to skip check)
MAILGUN_WEBHOOK_SECRET=
###< email providers ###
